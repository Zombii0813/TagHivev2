{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TagHive",
  "version": "0.6.0",
  "identifier": "com.taghive.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../src-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "resources/**/*"
    ],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "标签化文件管理器",
    "longDescription": "TagHive 是一个基于标签的文件管理工具，帮助用户高效地组织和查找文件。",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": true,
      "nsis": {
        "installerHooks": "./installer.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
